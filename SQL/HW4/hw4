-- Create procedure CreateGradeDetail
CREATE OR ALTER PROCEDURE CreateGradeDetail
(
    @GradeID INT,
    @AchievmentTypeID INT,
    @AchievmentPoints DECIMAL(10,2),--10-vkupen broj na cifri, 2-dve decimali
    @AchievmentMaxPoints DECIMAL(10,2),
    @AchievmentDate DATETIME = NULL
)
AS
BEGIN
    DECLARE @ParticipationRate DECIMAL(5,2);
    
    IF @AchievmentDate IS NULL
        SET @AchievmentDate = GETDATE();
 
    SELECT @ParticipationRate = ParticipationRate
    FROM AchievementType
    WHERE ID = @AchievmentTypeID;
    
    IF @ParticipationRate IS NULL
    BEGIN
        PRINT 'Error: AchievmentType with ID ' + CAST(@AchievmentTypeID AS VARCHAR) + ' does not exist!';
        RETURN;
    END

    INSERT INTO GradeDetails (GradeID, AchievementTypeID, AchievementPoints, AchievementMaxPoints, AchievementDate)
    VALUES (@GradeID, @AchievmentTypeID, @AchievmentPoints, @AchievmentMaxPoints, @AchievmentDate);
    
    IF @@ROWCOUNT = 0
    BEGIN
        PRINT 'Error: Grade details were not inserted!';
        RETURN;
    END
    
    PRINT 'Grade details have been successfully added!';
    PRINT '----------------------------------------';

    -- Return SUM of grade points based on formula 
    SELECT 
        @GradeID AS GradeID,
        SUM(AchievementPoints) AS TotalPoints,
        SUM(AchievementMaxPoints) AS TotalMaxPoints,
        CAST(SUM(AchievementPoints) * 100.0 / NULLIF(SUM(AchievementMaxPoints), 0) AS DECIMAL(10,2)) AS Percentage,--NULLIF se koristi za da se izbegne deljenje so nula
        CAST(SUM(AchievementPoints) * @ParticipationRate / 100.0 AS DECIMAL(10,2)) AS WeightedPoints
    FROM GradeDetails
    WHERE GradeID = @GradeID
    GROUP BY GradeID;
    
    PRINT '----------------------------------------';
    PRINT 'Procedure CreateGradeDetail finished successfully.';
END
GO




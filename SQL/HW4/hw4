-- Create procedure CreateGrade
CREATE OR ALTER PROCEDURE CreateGrade
(
  @StudentID INT, 
  @TeacherID INT, 
  @GradeValue INT, 
  @Comment NVARCHAR(MAX),
  @CreateDate DATETIME = NULL
  )
  AS
  BEGIN

    IF @CreateDate IS NULL
         SET @CreateDate = GETDATE()
    PRINT 'New grade has been added on date: ' + CONVERT(VARCHAR(10), @CreateDate, 104);

-- Insert grade header
INSERT INTO Grade (StudentID, TeacherID, Grade, Comment)
VALUES (@StudentID, @TeacherID, @GradeValue, @Comment);

-- Return total grades per student
 SELECT  @StudentID AS StudentID,
         COUNT(*) AS TotalGradesPerStudent
 FROM Grade
 WHERE StudentID = @StudentID
 GROUP BY StudentID;

 -- Return MAX grade per student and teacher
SELECT 
      StudentID,
      TeacherID,
      MAX(Grade) AS MaxGradePerStudentAndTeacher
FROM Grade
WHERE StudentID = @StudentID AND TeacherID = @TeacherID
GROUP BY StudentID, TeacherID;
END
GO



